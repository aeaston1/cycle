#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ ! -f "${ROOT_DIR}/mix.exs" ]; then
  printf 'cycle: cannot find mix.exs next to bin/cycle; use a packaged cycle executable for release installs\n' >&2
  exit 1
fi

cd "${ROOT_DIR}"

if command -v mise >/dev/null 2>&1; then
  exec mise exec -- mix run -e 'Cycle.CLI.main(System.argv())' -- "$@"
fi

exec mix run -e 'Cycle.CLI.main(System.argv())' -- "$@"
