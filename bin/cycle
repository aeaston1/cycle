#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0-dev"
DEFAULT_SYMPHONY_REPO="https://github.com/openai/symphony.git"
DEFAULT_SYMPHONY_REF="main"
DEFAULT_STATE_URL="http://127.0.0.1:4000/api/v1/state"

cycle_home() {
  printf '%s\n' "${CYCLE_HOME:-${HOME}/.local/share/cycle}"
}

cycle_config_home() {
  printf '%s\n' "${XDG_CONFIG_HOME:-${HOME}/.config}/cycle"
}

cycle_config_file() {
  printf '%s\n' "$(cycle_config_home)/config.env"
}

engine_dir() {
  local ref="${1:-$DEFAULT_SYMPHONY_REF}"
  printf '%s\n' "$(cycle_home)/engines/openai-symphony/${ref}"
}

usage() {
  cat <<'USAGE'
Cycle manages OpenAI Symphony engines across Linear projects.

Usage:
  cycle --version
  cycle help
  cycle doctor
  cycle status [--state-url URL]
  cycle start --workflow PATH [--port PORT] [--version REF] [--dry-run]
  cycle linear configure [--from-env | --api-key TOKEN | --print]
  cycle symphony install [--repo URL] [--version REF]
  cycle symphony path [--version REF]
  cycle project opt-in --repo URL
  cycle project discover [--limit N] [--raw]
  cycle service install
  cycle service status

Environment:
  CYCLE_HOME        State directory. Defaults to ~/.local/share/cycle
  XDG_CONFIG_HOME   Config parent. Defaults to ~/.config
  LINEAR_API_KEY    Linear API token used by discovery and Symphony workflows
USAGE
}

die() {
  printf 'cycle: %s\n' "$*" >&2
  exit 1
}

info() {
  printf '%s\n' "$*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

require_cmd() {
  local cmd="$1"
  have "$cmd" || die "missing required command: ${cmd}"
}

linear_api_key() {
  if [ -n "${LINEAR_API_KEY:-}" ]; then
    printf '%s\n' "$LINEAR_API_KEY"
    return 0
  fi

  local config
  config="$(cycle_config_file)"

  if [ -f "$config" ]; then
    sed -n "s/^LINEAR_API_KEY=['\"]\\{0,1\\}\\([^'\"]*\\)['\"]\\{0,1\\}$/\\1/p" "$config" | tail -n 1
  fi
}

parse_ref_and_repo() {
  SYMPHONY_REPO="$DEFAULT_SYMPHONY_REPO"
  SYMPHONY_REF="$DEFAULT_SYMPHONY_REF"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo)
        [ "$#" -ge 2 ] || die "--repo requires a URL"
        SYMPHONY_REPO="$2"
        shift 2
        ;;
      --version|--ref)
        [ "$#" -ge 2 ] || die "$1 requires a ref"
        SYMPHONY_REF="$2"
        shift 2
        ;;
      *)
        die "unknown option for symphony command: $1"
        ;;
    esac
  done
}

cmd_doctor() {
  local failed=0
  local key
  key="$(linear_api_key || true)"

  info "Cycle doctor"
  info "  config: $(cycle_config_home)"
  info "  state:  $(cycle_home)"

  for cmd in git codex mise; do
    if have "$cmd"; then
      info "  ok:    ${cmd} ($(command -v "$cmd"))"
    else
      info "  miss:  ${cmd}"
      failed=1
    fi
  done

  if have curl; then
    info "  ok:    curl ($(command -v curl))"
  else
    info "  warn:  curl is not installed; project discovery and status API checks will be limited"
  fi

  if have ruby; then
    info "  ok:    ruby ($(command -v ruby))"
  else
    info "  warn:  ruby is not installed; JSON formatting for discovery/status will be limited"
  fi

  if [ -n "$key" ]; then
    info "  ok:    LINEAR_API_KEY is configured"
  else
    info "  warn:  LINEAR_API_KEY is not configured"
  fi

  if [ "$failed" -ne 0 ]; then
    die "doctor found missing required commands"
  fi
}

cmd_linear_configure() {
  local token=""
  local print_only=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --api-key)
        [ "$#" -ge 2 ] || die "--api-key requires a token"
        token="$2"
        shift 2
        ;;
      --from-env)
        token="${LINEAR_API_KEY:-}"
        shift
        ;;
      --print)
        print_only=1
        shift
        ;;
      *)
        die "unknown option for linear configure: $1"
        ;;
    esac
  done

  if [ "$print_only" -eq 1 ]; then
    info "config file: $(cycle_config_file)"
    if [ -n "$(linear_api_key || true)" ]; then
      info "LINEAR_API_KEY: configured"
    else
      info "LINEAR_API_KEY: missing"
    fi
    return 0
  fi

  if [ -z "$token" ]; then
    token="${LINEAR_API_KEY:-}"
  fi

  [ -n "$token" ] || die "provide --api-key TOKEN or export LINEAR_API_KEY before running configure"

  case "$token" in
    *$'\n'*|*$'\r'*|*" "*)
      die "LINEAR_API_KEY contains whitespace; refusing to write it"
      ;;
  esac

  local config_dir
  config_dir="$(cycle_config_home)"
  mkdir -p "$config_dir"
  umask 077
  printf 'LINEAR_API_KEY=%s\n' "$token" >"$(cycle_config_file)"
  info "Saved Linear configuration to $(cycle_config_file)"
}

cmd_symphony_install() {
  parse_ref_and_repo "$@"
  require_cmd git

  local target
  target="$(engine_dir "$SYMPHONY_REF")"

  mkdir -p "$(dirname "$target")"

  if [ -d "$target/.git" ]; then
    info "Symphony engine already exists: $target"
    info "Updating with git fetch and checkout..."
    git -C "$target" fetch --tags origin
    git -C "$target" checkout "$SYMPHONY_REF"
    git -C "$target" pull --ff-only origin "$SYMPHONY_REF" || true
  elif [ -e "$target" ]; then
    die "target exists but is not a git checkout: $target"
  else
    info "Cloning Symphony from ${SYMPHONY_REPO}"
    git clone "$SYMPHONY_REPO" "$target"
    git -C "$target" checkout "$SYMPHONY_REF"
  fi

  if [ ! -f "$target/elixir/WORKFLOW.md" ]; then
    die "installed Symphony checkout did not contain elixir/WORKFLOW.md"
  fi

  info "Symphony installed at: $target"
}

cmd_symphony_path() {
  local ref="$DEFAULT_SYMPHONY_REF"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --version|--ref)
        [ "$#" -ge 2 ] || die "$1 requires a ref"
        ref="$2"
        shift 2
        ;;
      *)
        die "unknown option for symphony path: $1"
        ;;
    esac
  done

  engine_dir "$ref"
}

cmd_project_opt_in() {
  local repo=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo)
        [ "$#" -ge 2 ] || die "--repo requires a URL"
        repo="$2"
        shift 2
        ;;
      *)
        die "unknown option for project opt-in: $1"
        ;;
    esac
  done

  [ -n "$repo" ] || die "project opt-in requires --repo"

  cat <<YAML
cycle:
  enabled: true
  repo: ${repo}
YAML
}

linear_graphql() {
  local query="$1"
  local variables="$2"
  local key
  key="$(linear_api_key || true)"
  [ -n "$key" ] || die "LINEAR_API_KEY is not configured"
  require_cmd curl
  require_cmd ruby

  ruby -rjson -e 'print JSON.generate({"query" => ARGV[0], "variables" => JSON.parse(ARGV[1])})' "$query" "$variables" |
    curl --fail --silent --show-error \
      -H "Authorization: ${key}" \
      -H "Content-Type: application/json" \
      --data-binary @- \
      https://api.linear.app/graphql
}

cmd_project_discover() {
  local limit=50
  local raw=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --limit)
        [ "$#" -ge 2 ] || die "--limit requires a number"
        limit="$2"
        shift 2
        ;;
      --raw)
        raw=1
        shift
        ;;
      *)
        die "unknown option for project discover: $1"
        ;;
    esac
  done

  case "$limit" in
    ''|*[!0-9]*)
      die "--limit must be a positive integer"
      ;;
  esac

  local query variables response
  query='query CycleProjectDiscovery($first: Int!) { projects(first: $first) { nodes { id name slugId url description content } } }'
  variables="{\"first\":${limit}}"
  response="$(linear_graphql "$query" "$variables")"

  if [ "$raw" -eq 1 ]; then
    printf '%s\n' "$response"
    return 0
  fi

  ruby -rjson -e '
    payload = JSON.parse(STDIN.read)
    if payload["errors"]
      warn JSON.pretty_generate(payload["errors"])
      exit 1
    end
    projects = payload.dig("data", "projects", "nodes") || []
    matches = projects.filter_map do |project|
      source = [project["description"], project["content"]].compact.join("\n")
      block = source[/^cycle:\s*\n(?:[ \t]+.*\n?)*/m]
      next unless block
      next unless block.match?(/^[ \t]+enabled:\s*true\b/i)
      repo = block[/^[ \t]+repo:\s*(.+?)\s*$/i, 1] || ""
      [project["name"], project["slugId"], repo, project["url"]]
    end
    if matches.empty?
      puts "No opted-in Linear projects found."
    else
      puts "NAME\tSLUG\tREPO\tURL"
      matches.each { |row| puts row.join("\t") }
    end
  ' <<<"$response"
}

cmd_status() {
  local state_url="$DEFAULT_STATE_URL"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --state-url)
        [ "$#" -ge 2 ] || die "--state-url requires a URL"
        state_url="$2"
        shift 2
        ;;
      *)
        die "unknown option for status: $1"
        ;;
    esac
  done

  local default_engine
  default_engine="$(engine_dir "$DEFAULT_SYMPHONY_REF")"

  info "Cycle status"
  info "  config: $(cycle_config_home)"
  info "  state:  $(cycle_home)"

  if [ -d "$default_engine/.git" ]; then
    info "  engine: installed at $default_engine"
  else
    info "  engine: missing at $default_engine"
  fi

  if [ -n "$(linear_api_key || true)" ]; then
    info "  linear: configured"
  else
    info "  linear: missing LINEAR_API_KEY"
  fi

  if have curl; then
    local response
    if response="$(curl --fail --silent --show-error --max-time 2 "$state_url" 2>/dev/null)"; then
      if have ruby; then
        ruby -rjson -e '
          payload = JSON.parse(STDIN.read)
          running = payload["running"] || payload.dig("counts", "running") || []
          retrying = payload["retrying"] || []
          projects = payload["projects"] || []
          running_count = running.respond_to?(:length) ? running.length : running
          puts "  symphony: reachable"
          puts "  running: #{running_count}"
          puts "  retries: #{retrying.respond_to?(:length) ? retrying.length : retrying}"
          puts "  projects: #{projects.respond_to?(:length) ? projects.length : projects}"
        ' <<<"$response"
      else
        info "  symphony: reachable at $state_url"
      fi
    else
      info "  symphony: no status response from $state_url"
    fi
  else
    info "  symphony: curl unavailable; skipping status API check"
  fi
}

cmd_start() {
  local workflow=""
  local port=4000
  local ref="$DEFAULT_SYMPHONY_REF"
  local dry_run=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --workflow)
        [ "$#" -ge 2 ] || die "--workflow requires a path"
        workflow="$2"
        shift 2
        ;;
      --port)
        [ "$#" -ge 2 ] || die "--port requires a port"
        port="$2"
        shift 2
        ;;
      --version|--ref)
        [ "$#" -ge 2 ] || die "$1 requires a ref"
        ref="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      *)
        die "unknown option for start: $1"
        ;;
    esac
  done

  [ -n "$workflow" ] || die "cycle start requires --workflow PATH"

  local engine symphony_bin
  engine="$(engine_dir "$ref")"
  symphony_bin="$engine/elixir/bin/symphony"

  [ -x "$symphony_bin" ] || die "missing executable Symphony engine at $symphony_bin; run cycle symphony install first"
  [ -f "$workflow" ] || die "workflow file not found: $workflow"

  local cmd=("$symphony_bin" "--i-understand-that-this-will-be-running-without-the-usual-guardrails" "--port" "$port" "$workflow")

  if [ "$dry_run" -eq 1 ]; then
    printf '%q ' "${cmd[@]}"
    printf '\n'
    return 0
  fi

  exec "${cmd[@]}"
}

cmd_service_install() {
  cat <<'TEXT'
Service installation is not implemented yet.

Planned backing behavior:
  - generate a launchd plist on macOS
  - generate a systemd unit on Linux
  - point the service at a Cycle-managed Symphony engine
  - require explicit operator confirmation before replacing an existing service
TEXT
}

cmd_service_status() {
  cat <<'TEXT'
Service status is not implemented yet.

Use `cycle status` for the current local Cycle/Symphony status checks.
TEXT
}

cmd_symphony() {
  local sub="${1:-}"
  [ -n "$sub" ] || die "missing symphony subcommand"
  shift || true

  case "$sub" in
    install)
      cmd_symphony_install "$@"
      ;;
    path)
      cmd_symphony_path "$@"
      ;;
    *)
      die "unknown symphony subcommand: $sub"
      ;;
  esac
}

cmd_linear() {
  local sub="${1:-}"
  [ -n "$sub" ] || die "missing linear subcommand"
  shift || true

  case "$sub" in
    configure)
      cmd_linear_configure "$@"
      ;;
    *)
      die "unknown linear subcommand: $sub"
      ;;
  esac
}

cmd_project() {
  local sub="${1:-}"
  [ -n "$sub" ] || die "missing project subcommand"
  shift || true

  case "$sub" in
    opt-in)
      cmd_project_opt_in "$@"
      ;;
    discover)
      cmd_project_discover "$@"
      ;;
    *)
      die "unknown project subcommand: $sub"
      ;;
  esac
}

cmd_service() {
  local sub="${1:-}"
  [ -n "$sub" ] || die "missing service subcommand"
  shift || true

  case "$sub" in
    install)
      cmd_service_install "$@"
      ;;
    status)
      cmd_service_status "$@"
      ;;
    *)
      die "unknown service subcommand: $sub"
      ;;
  esac
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    --version|version)
      printf 'cycle %s\n' "$VERSION"
      ;;
    -h|--help|help)
      usage
      ;;
    doctor)
      shift
      cmd_doctor "$@"
      ;;
    status)
      shift
      cmd_status "$@"
      ;;
    start)
      shift
      cmd_start "$@"
      ;;
    linear)
      shift
      cmd_linear "$@"
      ;;
    symphony)
      shift
      cmd_symphony "$@"
      ;;
    project)
      shift
      cmd_project "$@"
      ;;
    service)
      shift
      cmd_service "$@"
      ;;
    *)
      usage >&2
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
