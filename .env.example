# Cycle local environment example.
# Copy values into your shell or local env manager. Do not commit real secrets.

# Linear API token used for project discovery and Linear issue operations.
LINEAR_API_KEY=

# Optional: override Cycle's state directory.
# Default: ~/.local/share/cycle
CYCLE_HOME=

# Optional: override the XDG config root.
# Cycle config defaults to ${XDG_CONFIG_HOME:-~/.config}/cycle.
XDG_CONFIG_HOME=

# Optional: local daemon/API URL for status checks.
# Default used by the current scaffold: http://127.0.0.1:4000/api/v1/state
CYCLE_STATUS_URL=

# Optional: override the upstream Symphony repository used by
# `cycle symphony install`.
# Default: https://github.com/openai/symphony.git
CYCLE_SYMPHONY_REPO=

# Optional: override the managed Symphony ref.
# Default: main
CYCLE_SYMPHONY_REF=

